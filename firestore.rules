rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Approved testimonials are publicly readable; writes via Admin SDK only
    match /testimonials/{testimonialId} {
      allow read: if resource.data.approved == true;
      allow write: if false;
    }

    // Feedback is private; reads and writes via Admin SDK only
    match /feedback/{docId} {
      allow read: if false;
      allow write: if false;
    }

    // Polls: authenticated users can read and update vote counts
    match /polls/{pollId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes']);
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['votes']);

      // Per-user vote record: users can read their own and create once
      match /userVotes/{uid} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null && request.auth.uid == uid
          && request.resource.data.keys().hasOnly(['option', 'votedAt']);
        allow update, delete: if false;
      }
    }

    match /users/{userId} {
      // Users can read their own document (pro status)
      // Only admin SDK (Cloud Functions) can write user doc
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;

      // Meta subcollection (AI usage tracking) — read-only for client
      match /meta/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      // Sync subcollection — clients can read their own data, writes only via Admin SDK (Cloud Functions)
      match /sync/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }
  }
}
